<?xml version="1.0"?>
<PluginConfig>

	<Field id="indigo_server_ip" type="textfield" defaultValue="192.168.100.160">
		<Label>Indigo Server IP:</Label>
	</Field>
	<Field id="hlpServerIp" type="label" fontSize="mini" alignWithControl="true">
		<Label>IP address Shelly devices use to reach Indigo for webhook callbacks.</Label>
	</Field>

	<Field id="sep0" type="separator"/>

	<Field id="discovery_subnets" type="textfield" defaultValue="192.168.4">
		<Label>Discovery Subnets:</Label>
	</Field>
	<Field id="hlpSubnet" type="label" fontSize="mini" alignWithControl="true">
		<Label>First three octets only. Comma-separate multiple subnets for complex networks.
Examples: 192.168.4    or    192.168.4, 192.168.10, 10.0.1
Discovery scans .1 to .254 on each subnet.</Label>
	</Field>

	<Field id="sep1" type="separator"/>

	<Field id="timeout_secs" type="menu" defaultValue="3">
		<Label>HTTP Request Timeout:</Label>
		<List>
			<Option value="2">2 seconds</Option>
			<Option value="3">3 seconds (default)</Option>
			<Option value="5">5 seconds</Option>
			<Option value="10">10 seconds</Option>
		</List>
	</Field>

	<Field id="sep2" type="separator"/>

	<!-- ── Shelly Authentication ─────────────────────────────────────────── -->

	<Field id="shelly_username" type="textfield" defaultValue="">
		<Label>Shelly Username:</Label>
	</Field>
	<Field id="shelly_password" type="textfield" defaultValue="">
		<Label>Shelly Password:</Label>
	</Field>
	<Field id="hlpAuth" type="label" fontSize="mini" alignWithControl="true">
		<Label>Optional. Leave blank if your Shelly devices do not have authentication enabled.
If set, Digest Auth is used on all RPC calls. All devices must share the same credentials.</Label>
	</Field>

	<Field id="sep3" type="separator"/>

	<Field id="sep4" type="separator"/>

	<!-- ── Firmware Notifications ───────────────────────────────────────── -->

	<Field id="firmware_notify_enabled" type="checkbox" defaultValue="false">
		<Label>Daily Firmware Update Notifications:</Label>
	</Field>
	<Field id="hlpFirmware" type="label" fontSize="mini" alignWithControl="true">
		<Label>Check all devices once per day for available firmware updates. Results are logged and sent via Pushover if the Pushover plugin is installed and enabled.</Label>
	</Field>

	<Field id="sep5" type="separator"/>

	<Field id="stale_minutes" type="menu" defaultValue="10">
		<Label>Offline Detection Threshold:</Label>
		<List>
			<Option value="5">5 minutes</Option>
			<Option value="10">10 minutes (default)</Option>
			<Option value="15">15 minutes</Option>
			<Option value="30">30 minutes</Option>
			<Option value="60">60 minutes</Option>
		</List>
	</Field>
	<Field id="hlpStale" type="label" fontSize="mini" alignWithControl="true">
		<Label>Mark a device offline if no response (poll or webhook) received within this time.</Label>
	</Field>

	<Field id="sep6" type="separator"/>

	<Field id="logLevel" type="menu" defaultValue="20">
		<Label>Log Level:</Label>
		<List>
			<Option value="5">Detailed Debugging</Option>
			<Option value="10">Debugging</Option>
			<Option value="20">Informational (default)</Option>
			<Option value="30">Warnings Only</Option>
			<Option value="40">Errors Only</Option>
		</List>
	</Field>

</PluginConfig>

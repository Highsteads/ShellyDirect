<?xml version="1.0"?>
<Devices>

	<!-- ============================================================
	     shellyRelay
	     Single or multi-channel relay with optional power monitoring.
	     Covers: Plus Plug UK/S/IT/US, Shelly 1/1PM/Mini, Pro 1/1PM,
	             Gen 3/4 variants, individual channels of Plus 2PM / Pro 4PM.
	     ============================================================ -->
	<Device type="relay" id="shellyRelay">
		<Name>Shelly Relay</Name>
		<ConfigUI>
			<Field id="ip_address" type="textfield" defaultValue="">
				<Label>IP Address:</Label>
			</Field>
			<Field id="hlpIp" type="label" fontSize="mini" alignWithControl="true">
				<Label>Local IP address of the Shelly device (e.g. 192.168.4.10)</Label>
			</Field>
			<Field id="sep1" type="separator"/>
			<Field id="channel_id" type="menu" defaultValue="0">
				<Label>Channel:</Label>
				<List>
					<Option value="0">0 - Single channel or Ch 1</Option>
					<Option value="1">1 - Ch 2 (Plus 2PM / Pro 4PM)</Option>
					<Option value="2">2 - Ch 3 (Pro 4PM)</Option>
					<Option value="3">3 - Ch 4 (Pro 4PM)</Option>
				</List>
			</Field>
			<Field id="hlpChan" type="label" fontSize="mini" alignWithControl="true">
				<Label>Use 0 for single-channel devices. For Pro 4PM or Plus 2PM create one device per channel.</Label>
			</Field>
			<Field id="sep2" type="separator"/>
			<Field id="has_pm" type="checkbox" defaultValue="true">
				<Label>Has Power Monitoring (PM):</Label>
			</Field>
			<Field id="hlpPm" type="label" fontSize="mini" alignWithControl="true">
				<Label>Enable for 1PM, 1PM Mini, Plus Plug UK, Plus 2PM, Pro 4PM. Disable for Shelly 1 and 1 Mini.</Label>
			</Field>
			<Field id="sep3" type="separator"/>
			<Field id="addon_temp" type="checkbox" defaultValue="false">
				<Label>Has Temperature Add-on:</Label>
			</Field>
			<Field id="hlpAddon" type="label" fontSize="mini" alignWithControl="true">
				<Label>Enable if a Shelly Plus Add-on with DS18B20 probe is fitted. Reads probe 0 into addon_temp_c state.</Label>
			</Field>
			<Field id="sep4" type="separator"/>
			<Field id="lock_off" type="checkbox" defaultValue="false">
				<Label>Lock Off (power monitor only):</Label>
			</Field>
			<Field id="hlpLock" type="label" fontSize="mini" alignWithControl="true">
				<Label>Prevent this device being turned off. Turn On commands still work.</Label>
			</Field>
			<Field id="sep5" type="separator"/>
			<Field id="power_alert_enabled" type="checkbox" defaultValue="false">
				<Label>High Power Alert:</Label>
			</Field>
			<Field id="power_alert_watts" type="textfield" defaultValue="2000"
			       visibleBindingId="power_alert_enabled" visibleBindingValue="true">
				<Label>Alert Threshold (W):</Label>
			</Field>
			<Field id="hlpAlert" type="label" fontSize="mini" alignWithControl="true"
			       visibleBindingId="power_alert_enabled" visibleBindingValue="true">
				<Label>Fires highPowerAlert trigger and logs a warning when power exceeds this value.</Label>
			</Field>
			<Field id="sep6" type="separator"/>
			<Field id="mirror_to_variable" type="checkbox" defaultValue="false">
				<Label>Mirror States to Variables:</Label>
			</Field>
			<Field id="hlpMirror" type="label" fontSize="mini" alignWithControl="true">
				<Label>Write key states to Indigo variables in the ShellyDirect folder for use in control pages and scripts.</Label>
			</Field>
			<Field id="sep7" type="separator"/>
			<Field id="poll_interval" type="menu" defaultValue="30">
				<Label>Poll Interval:</Label>
				<List>
					<Option value="10">Every 10 seconds</Option>
					<Option value="30">Every 30 seconds (default)</Option>
					<Option value="60">Every 60 seconds</Option>
					<Option value="120">Every 2 minutes</Option>
				</List>
			</Field>
		</ConfigUI>
		<States>
			<State id="power_watts">
				<ValueType>Float</ValueType>
				<TriggerLabel>Power (W)</TriggerLabel>
				<ControlPageLabel>Power</ControlPageLabel>
			</State>
			<State id="voltage">
				<ValueType>Float</ValueType>
				<TriggerLabel>Voltage (V)</TriggerLabel>
				<ControlPageLabel>Voltage</ControlPageLabel>
			</State>
			<State id="current_amps">
				<ValueType>Float</ValueType>
				<TriggerLabel>Current (A)</TriggerLabel>
				<ControlPageLabel>Current</ControlPageLabel>
			</State>
			<State id="energy_kwh_today">
				<ValueType>Float</ValueType>
				<TriggerLabel>Energy Today (kWh)</TriggerLabel>
				<ControlPageLabel>Today kWh</ControlPageLabel>
			</State>
			<State id="energy_kwh_month">
				<ValueType>Float</ValueType>
				<TriggerLabel>Energy This Month (kWh)</TriggerLabel>
				<ControlPageLabel>Month kWh</ControlPageLabel>
			</State>
			<State id="energy_cost_today">
				<ValueType>Float</ValueType>
				<TriggerLabel>Energy Cost Today</TriggerLabel>
				<ControlPageLabel>Cost Today</ControlPageLabel>
			</State>
			<State id="energy_cost_month">
				<ValueType>Float</ValueType>
				<TriggerLabel>Energy Cost This Month</TriggerLabel>
				<ControlPageLabel>Cost Month</ControlPageLabel>
			</State>
			<State id="device_temp_c">
				<ValueType>Float</ValueType>
				<TriggerLabel>Device Temperature (C)</TriggerLabel>
				<ControlPageLabel>Dev Temp</ControlPageLabel>
			</State>
			<State id="addon_temp_c">
				<ValueType>Float</ValueType>
				<TriggerLabel>Add-on Probe Temperature (C)</TriggerLabel>
				<ControlPageLabel>Probe Temp</ControlPageLabel>
			</State>
			<State id="deviceOnline">
				<ValueType>Boolean</ValueType>
				<TriggerLabel>Device Online</TriggerLabel>
				<ControlPageLabel>Online</ControlPageLabel>
			</State>
		</States>
	</Device>

